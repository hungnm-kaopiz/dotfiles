#!/bin/bash
{{- if eq .chezmoi.osRelease.id "ubuntu" }}
set -uo pipefail

ROOT="{{ .chezmoi.workingTree }}"
TMPDIRS=()
cleanup() { rm -rf "${TMPDIRS[@]+"${TMPDIRS[@]}"}"; }
trap cleanup EXIT

# shellcheck source=scripts/install-common.sh
source "${ROOT}/scripts/install-common.sh"

run_step "apt update" sudo apt-get update
run_step "apt install software-properties-common" sudo apt-get install -y software-properties-common
run_step "enable universe repo" sudo add-apt-repository -y universe
run_step "apt update (after universe)" sudo apt-get update
run_step "apt upgrade" sudo apt-get upgrade -y
run_step "apt autoremove" sudo apt-get autoremove -y
run_step "apt clean" sudo apt-get clean

apt_install_packages "${ROOT}/packages/ubuntu.txt"
install_eza

run_step "set locale" sudo localectl set-locale LANG=en_US.UTF-8
if [ "$SHELL" != "$(command -v zsh)" ]; then
  run_step "set default shell to zsh" chsh -s "$(command -v zsh)"
fi

mkdir -p "${XDG_STATE_HOME:-$HOME/.local/state}/zsh"

echo ""
echo "APT setup complete."

{{- end }}
