[color]
	ui = true

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current
	followTags = true

[pull]
	rebase = false
	ff = only

[fetch]
	prune = true
	pruneTags = true

[branch]
	sort = -committerdate

[rerere]
	enabled = true
	autoupdate = true

[rebase]
	autoStash = true
	updateRefs = true

[merge]
	conflictStyle = zdiff3

[diff]
	colorMoved = default

[core]
	pager = delta
	editor = vi

[interactive]
	diffFilter = delta --color-only

[delta]
	features = side-by-side line-numbers decorations hyperlinks
	syntax-theme = Dracula
	navigate = true
	dark = true

[delta "side-by-side"]
	side-by-side = true

[delta "line-numbers"]
	line-numbers = true

[delta "decorations"]
	commit-decoration-style = bold yellow box ul
	file-style = bold blue
	file-decoration-style = blue ul
	hunk-header-style = file line-number syntax
	hunk-header-decoration-style = blue box

[delta "hyperlinks"]
	hyperlinks = true
	hyperlinks-file-link-format = "file://{path}"

[github]
	user = {{ .github_user | quote }}

[user]
	name = {{ .name | quote }}
	email = {{ .email | quote }}
